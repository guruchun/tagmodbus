<log4net>
  <appender name="Console" type="log4net.Appender.ConsoleAppender">
    <layout type="log4net.Layout.PatternLayout">
      <!-- Pattern to output the caller's file name and line number -->
      <!-- conversionPattern value="%5level [%thread] (%file:%line) - %message%newline" / -->
      <conversionPattern value="%5level [%thread] (%class:%method:%line) - %message%newline" />
    </layout>
  </appender>

  <appender name="RollingConsoleFile" type="log4net.Appender.RollingFileAppender">
    <file value="log/console.log" />
    <appendToFile value="true" />
    <maximumFileSize value="100KB" />
    <maxSizeRollBackups value="2" />

    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{HH:mm:ss,fff} %5level [%thread] (%class:%method:%line) - %message%newline" />
    </layout>
  </appender>

  <!-- appender name="RollingModbusServer" type="log4net.Appender.RollingFileAppender">
        <file value="log/modbusServer.log" />
        <appendToFile value="true" />
        <maximumFileSize value="100KB" />
        <maxSizeRollBackups value="2" />

        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%logger - %message%newline" />
        </layout>
    </appender -->
  <appender name="RollingModbus" type="log4net.Appender.RollingFileAppender">
    <file value="log/modbus.log" />
    <appendToFile value="true" />
    <maximumFileSize value="100KB" />
    <maxSizeRollBackups value="2" />

    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{HH:mm:ss,fff} %message%newline" />
    </layout>
  </appender>

  <!-- root>
        <level value="DEBUG" />
        <appender-ref ref="Console" />
        <appender-ref ref="RollingDebugFile" />
    </root -->

  <logger name="Console">
    <level value="DEBUG" />
    <appender-ref ref="Console" />
    <appender-ref ref="RollingConsoleFile" />
  </logger>

  <!-- Print only messages of level INFO or above in the package Com.Foo -->
  <logger name="ModbusClient">
    <level value="INFO" />
    <appender-ref ref="RollingModbus" />
  </logger>
  <!-- logger name="ModbusServer">
        <level value="INFO" />
        <appender-ref ref="RollingModbusServer" />
    </logger -->
</log4net>